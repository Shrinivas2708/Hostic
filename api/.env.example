IMAGEKIT_PUBLIC_KEY=<public_key>
IMAGEKIT_PRIVATE_KEY=<private_key>
IMAGEKIT_URL_ENDPOINT=<endpoint>
PORT=5000
DATABASE_URL=mongodb://localhost:27017/hostic
JWT_SECRET=secret
REDIS_URL=redis://localhost:6379
R2_ENDPOINT=https://<your-account>.r2.cloudflarestorage.com
R2_BUCKET=<bucket-name>
R2_ACCESS_KEY_ID=<key>
R2_SECRET_ACCESS_KEY=<secret>
API_PUBLIC_URL=http://localhost:5000
DEPLOY_URL_TEMPLATE=http://{slug}.localhost:8080
GITHUB_CALLBACK_URL=http://localhost:5000/api/github/callback
FRONTEND_URL=http://localhost:5173
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Local npm cache is always on disk per deployment. Set true to also upload to R2 (multi-machine workers).
DEPS_CACHE_SYNC_R2=false
# Cap build container resources on your laptop (optional). Omit on dedicated Linux builders.
BUILD_DOCKER_CPUS=2
BUILD_DOCKER_MEMORY=2g
