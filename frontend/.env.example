# API (Express + Socket.IO on the same port)
VITE_API_URL=http://localhost:5000/api

# Optional — only if socket is on a different host than the API origin
# VITE_SOCKET_URL=http://localhost:5000

# Live deployment URL — {slug} is replaced with the deployment slug
# Local proxy:
VITE_DEPLOY_URL_TEMPLATE=http://{slug}.localhost:8080
# Production:
# VITE_DEPLOY_URL_TEMPLATE=https://{slug}.apps.shribuilds.in
